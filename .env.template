# Environment Selection
ASPNETCORE_ENVIRONMENT=Development

# Database Configuration (Docker Postgres)
DB_HOST=db
DB_NAME=portfolio
DB_USER=user
DB_PASSWORD=password

# Authentication (Supabase)
# LOCAL_DEV_BYPASS_AUTH=true # Uncomment to bypass authentication locally
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
ADMIN_EMAIL=your-email@example.com

# AI Chatbot Configuration
# Provider can be 'Ollama' or 'Gemini'
AI_PROVIDER=Ollama
AI_TEMPERATURE=0.1

# If using Ollama (Native Host -> http://host.containers.internal:11434)
OLLAMA_ENDPOINT=http://ollama:11434

# If using Gemini
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-1.5-flash
